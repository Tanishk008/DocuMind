# DocuMind AI — Environment Variables Template
# Copy this file to .env.local and fill in your keys

# --- REQUIRED ---
# Google Gemini API Key — get at https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# --- OPTIONAL: Additional Gemini API Keys (from different Google accounts) ---
# DocuMind will try each key in order. When one key's daily quota is exhausted,
# it automatically falls over to the next key. Add as many as you want (up to KEY_10).
# Get free keys at: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY_2=your_second_gemini_api_key_here
# GOOGLE_GENERATIVE_AI_API_KEY_3=your_third_gemini_api_key_here
# GOOGLE_GENERATIVE_AI_API_KEY_4=your_fourth_gemini_api_key_here
# ... add more up to GOOGLE_GENERATIVE_AI_API_KEY_10

# --- OPTIONAL (enables Pinecone persistent vector store) ---
# Get at https://pinecone.io — create an index named "documind" with 768 dimensions
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=documind

# --- OPTIONAL (enables Cohere reranker for better retrieval) ---
# Get at https://cohere.com
COHERE_API_KEY=your_cohere_api_key_here
